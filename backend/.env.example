# ============================================================
# TalentSense HR - 后端本地开发环境配置
# ------------------------------------------------------------
# 使用方法：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 按下方注释逐项填写（带【必填】标记的必须填写）
#   3. 本地开发时，需自行启动 MongoDB / Redis / Milvus / MinIO
#      可用 docker-compose up mongo redis milvus minio minio-init 仅启动基础设施
#
# 安全提醒：
#   - .env 文件包含敏感信息，已被 .gitignore 忽略，切勿提交到 Git
#   - 生产环境务必修改所有默认密码
# ============================================================

# ---------- 服务 ----------
APP_NAME=TalentSense HR
DEBUG=true
API_V1_PREFIX=/api/v1

# ---------- MongoDB【必填】 ----------
# 本地连接格式：mongodb://用户名:密码@host:port/?authSource=admin
# 若 MongoDB 无认证，可用：mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB=talentsense

# ---------- Redis【必填】 ----------
# 有密码格式：redis://:密码@host:port/0
REDIS_URL=redis://localhost:6379/0

# ---------- Milvus ----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=resumes

# ---------- MinIO【必填】 ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes
MINIO_SECURE=false

# ---------- LLM【必填】 ----------
# 通义千问 / DeepSeek / OpenAI 兼容接口的 API Key
# 获取方式：https://dashscope.console.aliyun.com/ 申请通义千问 Key
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ---------- JWT【必填】 ----------
# 生产环境必须改为随机字符串
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- 模型路径 ----------
# 本地开发需提前下载 BGE-M3 与 BGE-Reranker 模型到以下路径
# 下载方式见 README.md「本地开发 - 模型下载」章节
BGE_M3_PATH=./models/bge-m3
BGE_RERANKER_PATH=./models/bge-reranker-v2-m3

# ---------- 检索参数（可选，有默认值） ----------
HYBRID_DENSE_WEIGHT=1.0
HYBRID_SPARSE_WEIGHT=0.7
RETRIEVE_TOP_K=20
RERANK_TOP_K=10

# ---------- 管理员初始账号【必填】 ----------
# 后端首次启动时自动创建的管理员账号
# 登录使用邮箱 + 密码方式
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@test.com

# ---------- 可观测性（可选） ----------
# Sentry DSN（不填则不启用错误追踪）
SENTRY_DSN=
# Sentry 性能采样率 0.0~1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
# 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
