# ============================================================
# TalentSense HR Docker Compose 环境配置
# 使用方法：复制为 .env，修改 LLM_API_KEY 和 JWT_SECRET 后执行 docker-compose up -d
# ============================================================

# ---------- LLM 配置（必填） ----------
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ---------- 安全配置（生产环境务必修改） ----------
JWT_SECRET=change-this-to-a-random-secret-string-in-production

# ---------- 管理员初始账号 ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=a****@********

# ---------- MinIO 对象存储 ----------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes

# ---------- MongoDB ----------
MONGO_DB=talentsense

# ---------- Milvus ----------
MILVUS_COLLECTION=resumes
