# ============================================================
# TalentSense HR - Docker Compose 环境配置模板
# ------------------------------------------------------------
# 使用方法：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 按下方注释逐项填写（带【必填】标记的必须填写）
#   3. 执行 docker-compose up -d --build 启动
#
# 安全提醒：
#   - .env 文件包含敏感信息，已被 .gitignore 忽略，切勿提交到 Git
#   - 生产环境务必修改所有默认密码，不要使用示例值
#   - LLM_API_KEY 是付费资源，妥善保管，定期轮换
# ============================================================

# ==================== LLM 配置【必填】 ====================
# 通义千问 / DeepSeek / OpenAI 兼容接口的 API Key
# 获取方式：https://dashscope.console.aliyun.com/ 申请通义千问 Key
LLM_API_KEY=sk-your-api-key-here
# LLM 接口地址（通义千问兼容模式，也支持 DeepSeek / OpenAI）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM 模型名（通义千问用 qwen-plus，DeepSeek 用 deepseek-chat）
LLM_MODEL=qwen-plus

# ==================== 安全配置【必填】 ====================
# JWT 签名密钥，生产环境必须改为随机字符串
# 生成方式（任选其一）：
#   Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   OpenSSL: openssl rand -base64 32
JWT_SECRET=please-change-this-to-a-random-secret-string

# ==================== 基础设施密码【必填】 ====================
# 以下密码用于 MongoDB / Redis / MinIO / Milvus 容器初始化
# 生产环境请使用强密码（建议 16 位以上，含大小写字母+数字+特殊字符）
# 本地测试可使用简单值，但切勿在生产环境使用默认值

# MongoDB root 用户名与密码
MONGO_ROOT_USERNAME=hrcopilot
MONGO_ROOT_PASSWORD=change-this-to-a-strong-password

# Redis 密码
REDIS_PASSWORD=change-this-to-a-strong-password

# MinIO root 用户名与密码（同时被 Milvus 使用）
MINIO_ROOT_USER=hrcopilot
MINIO_ROOT_PASSWORD=change-this-to-a-strong-password

# ==================== 管理员初始账号【必填】 ====================
# 后端首次启动时自动创建的管理员账号
# 登录使用邮箱 + 密码方式
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-secure-password
ADMIN_EMAIL=admin@example.com

# ==================== 数据库名称（可选，有默认值） ====================
# MongoDB 数据库名
MONGO_DB=talentsense
# Milvus 集合名
MILVUS_COLLECTION=resumes
# MinIO bucket 名（存储简历文件）
MINIO_BUCKET=resumes

# ==================== 可观测性（可选） ====================
# Sentry DSN（不填则不启用错误追踪，留空即可）
SENTRY_DSN=
# Sentry 性能采样率 0.0~1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
# 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 运行环境（生产设为 false 会输出 JSON 结构化日志）
DEBUG=false
